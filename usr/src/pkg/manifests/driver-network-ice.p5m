<include global_zone_only_component>
set name=pkg.fmri value=pkg:/driver/network/ice@$(PKGVERS)
set name=pkg.summary value="Intel E810 Ethernet Driver"
set name=pkg.description value="Intel E810 Ethernet Driver"
set name=info.classification \
    value=org.opensolaris.category.2008:Drivers/Networking
set name=variant.arch value=i386
dir  path=kernel group=sys
dir  path=kernel/drv group=sys
dir  path=kernel/drv/$(ARCH64) group=sys
file path=kernel/drv/$(ARCH64)/ice group=sys
file path=kernel/drv/ice.conf group=sys
dir  path=kernel/firmware/ice/ice-1.3.41.0.pkg group=sys
link path=kernel/firmware/ice/ice.pkg target=ice-1.3.41.0.pkg
dir  path=usr/share/man
dir  path=usr/share/man/man4d
file path=usr/share/man/man4d/ice.4d
driver name=ice perms="* 0666 root sys" clone_perms="ice 0666 root sys" \
